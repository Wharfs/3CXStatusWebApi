<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <StartupObject>WebAPI.Program</StartupObject>
    <RootNamespace>WebAPI</RootNamespace>
    <AssemblyName>WebAPICore</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <!--
      Build-time location of 3cxpscomcpp2.dll (the 3CX Call Control assembly
      this service wraps). It is a managed .NET assembly, so any OS with
      .NET 8 can build against it — the path just has to be reachable at
      build time.

      Override with `dotnet build -p:PbxBinPath=/absolute/path` or by setting
      a PbxBinPath environment variable before building.

      Defaults:
        Linux (3CX v20 Debian server): /var/lib/3cxpbx/Instance1/Bin
        Windows (legacy 3CX for Windows install): C:\Program Files\3CX Phone System\Bin

      If building on a machine that has neither path, scp the DLL off a
      running 3CX server and set PbxBinPath to point at its folder.

      <Private>false</Private> keeps the DLL out of the build output — at
      runtime it is loaded from the actual 3CX install via the
      AssemblyResolve hook in Program.cs.
    -->
    <PbxBinPath Condition="'$(PbxBinPath)' == '' AND '$(OS)' == 'Windows_NT'">C:\Program Files\3CX Phone System\Bin</PbxBinPath>
    <PbxBinPath Condition="'$(PbxBinPath)' == ''">/var/lib/3cxpbx/Instance1/Bin</PbxBinPath>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="3cxpscomcpp2">
      <HintPath>$(PbxBinPath)/3cxpscomcpp2.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FastEndpoints" Version="5.32.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="8.0.2" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Ini" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" Version="8.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="8.0.1" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="appsettings.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
